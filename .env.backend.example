# Copy to .env.backend on the server: cp .env.backend.example .env.backend
PORT=8000
NODE_ENV=production

# DB credentials must match .env.docker (DB_HOST/DB_PORT are set in docker-compose.yml)
DB_NAME=trading_journal
DB_USER=trading_user
DB_PASSWORD=MYSQLacorda@123

JWT_SECRET=EIj7s0qDM2Hw0P3osgyWZF5fAMDvJOLufbvGRwDMRZo=
JWT_REFRESH_SECRET=M6kyMG3Ku434V+QRoKc62gduol9BYeE/NglZqFPGxR4=

CORS_ORIGIN=https://trade2learn.xyz,https://www.trade2learn.xyz
FRONTEND_URL_HTTP=http://trade2learn.xyz
FRONTEND_URL_HTTPS=https://trade2learn.xyz
COOKIE_DOMAIN=.trade2learn.xyz
# Set to "true" only after SSL is live (Part 7). Omit or use "false" on HTTP-only servers.
COOKIE_SECURE=false

# Set to "true" to disable all outbound email (Gmail setup not required).
# When disabled: registration auto-verifies users, login skips verification gate,
# and forgot-password returns the temp password directly in the API response.
DISABLE_EMAIL=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_OAUTH_USER=
