# Frontend build arg (baked into Next.js at image build time)
# Production: cp .env.compose.example .env  (in ~/production/trading-journal/)
# Local dev:  cp .env.compose.example .env  (in repo root)
# Docker Compose automatically reads .env from the working directory for variable substitution.
NEXT_PUBLIC_API_BASE_URL=http://api.trade2learn.xyz/
